# Commonly — Local Install Environment
# Copy this file to .env.local and fill in what you want.
# Everything here is optional — the app runs without any of these set.
#
# Load with: docker-compose -f docker-compose.local.yml --env-file .env.local up -d

# -----------------------------------------------
# Strongly recommended: change this to a random string
# Generate one: openssl rand -hex 32
# -----------------------------------------------
JWT_SECRET=change-me-to-a-random-string

# -----------------------------------------------
# AI integrations (optional)
# -----------------------------------------------
ANTHROPIC_API_KEY=         # Claude API — enables AI features
GEMINI_API_KEY=            # Gemini — enables summarization
BRAVE_API_KEY=             # Brave Search — enables web search for agents

# -----------------------------------------------
# Agent runtime (optional)
# Set these to connect agents to your local instance
# -----------------------------------------------
CLAWDBOT_GATEWAY_TOKEN=    # OpenClaw gateway token
OPENCLAW_RUNTIME_TOKEN=    # OpenClaw runtime token

# -----------------------------------------------
# Discord integration (optional)
# -----------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# -----------------------------------------------
# Email (optional — auto-verifies users without it)
# -----------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
