# Copy this file to .env for local development.
# The defaults below are enough for the Docker Compose dev stack to boot.

# Core app
NODE_ENV=development
PORT=5000
JWT_SECRET=development-jwt-secret
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000
COMPOSE_PROJECT_NAME=commonly

# Databases
MONGO_URI=mongodb://mongo:27017/commonly
PG_USER=postgres
PG_PASSWORD=postgres
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=commonly

# Email (optional)
SMTP2GO_API_KEY=
SMTP2GO_FROM_EMAIL=
SMTP2GO_FROM_NAME=
SMTP2GO_BASE_URL=

# AI / LLM providers (optional)
# Set at least one provider key if you want AI-backed features locally.
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_MASTER_KEY=dev-litellm-key
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_CHAT_MODEL=
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=

# First-party integrations (optional)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
CLAWDBOT_DISCORD_CLIENT_ID=
CLAWDBOT_DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Social / OAuth integrations (optional)
X_API_BASE_URL=https://api.x.com/2
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=
INSTAGRAM_GRAPH_API_BASE=https://graph.facebook.com/v19.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Local external agent runtimes (optional)
# commonly-bot can stay unprovisioned on first boot; use Agents Hub to generate the runtime token later.
COMMONLY_SUMMARIZER_RUNTIME_TOKEN=
COMMONLY_SUMMARIZER_USER_TOKEN=
OPENCLAW_RUNTIME_TOKEN=
OPENCLAW_USER_TOKEN=
OPENCLAW_B_RUNTIME_TOKEN=
OPENCLAW_B_USER_TOKEN=
CLAWDBOT_GATEWAY_TOKEN=
CLAWDBOT_GATEWAY_PORT=18789
CLAWDBOT_GATEWAY_BIND=lan
CLAWDBOT_DOCKERFILE=Dockerfile.commonly
COMMONLY_BASE_URL=http://backend:5000
COMMONLY_API_URL=http://backend:5000
CLAUDE_CREDENTIALS_PATH=

# Research / media skills for OpenClaw (optional)
TAVILY_API_KEY=
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
DEEPGRAM_API_KEY=

# Extra bridge agents (optional)
NEWSHOUND_RUNTIME_TOKEN=
NEWSHOUND_USER_TOKEN=
SOCIALPULSE_RUNTIME_TOKEN=
SOCIALPULSE_USER_TOKEN=
