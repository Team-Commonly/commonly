# ===========================
# ✅ Database Configuration
# ===========================
MONGO_URI=mongodb://mongo:27017/commonly

# ===========================
# ✅ PostgreSQL Configuration
# ===========================
PG_USER=postgres
PG_PASSWORD=postgres
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=commonly
PG_SSL_CA_PATH=/app/ca.pem

# ===========================
# ✅ Backend Configuration
# ===========================
JWT_SECRET=your_jwt_secret
PORT=5000
NODE_ENV=development

# ===========================
# ✅ Email Configuration
# ===========================
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_email@example.com

# ===========================
# ✅ Frontend Configuration
# ===========================
FRONTEND_URL=http://localhost:3000

# ===========================
# ✅ AI Configuration
# ===========================
GEMINI_API_KEY=your_gemini_api_key

# ===========================
# ✅ Commonly Discord Bot (slash commands)
# ===========================
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_PUBLIC_KEY=your_discord_public_key
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ===========================
# ✅ Clawdbot Discord Bot (AI agent - separate bot)
# ===========================
# Create at https://discord.com/developers/applications
CLAWDBOT_DISCORD_CLIENT_ID=
CLAWDBOT_DISCORD_BOT_TOKEN=

# ===========================
# ✅ Clawdbot Channels (Slack, Telegram)
# ===========================
# Slack: Enable Socket Mode, add event subscriptions (message.channels, app_mention)
# OAuth scopes: channels:history, chat:write, groups:history, im:history, app_mentions:read
SLACK_APP_TOKEN=xapp-1-...     # App-level token from Socket Mode settings
SLACK_BOT_TOKEN=xoxb-...       # Bot User OAuth Token from OAuth & Permissions
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ===========================
# ✅ Clawdbot Commonly Integration
# ===========================
COMMONLY_API_URL=http://backend:5000
COMMONLY_API_TOKEN=your_commonly_agent_token

# ===========================
# ✅ External Agents
# ===========================
COMMONLY_BOT_TOKEN=your_commonly_bot_token
CLAWDBOT_BRIDGE_TOKEN=your_clawdbot_bridge_token
CLAWDBOT_GATEWAY_TOKEN=your_gateway_token