# Development environment optimizations
GENERATE_SOURCEMAP=false
ESLINT_NO_DEV_ERRORS=true
FAST_REFRESH=true
TSC_COMPILE_ON_ERROR=true

# Reduce file watching CPU usage
CHOKIDAR_USEPOLLING=false
WATCHPACK_POLLING=false

# React app settings
# For local dev with docker-compose: http://localhost:5000
# For local k8s (kind): http://localhost/api
REACT_APP_API_URL=http://localhost:5000
REACT_APP_INTEGRATION_REDIRECT_BASE_URL=http://localhost:3000
